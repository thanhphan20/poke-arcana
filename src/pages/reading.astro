---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import QuestionChips from '../components/spread/QuestionChips.astro';
import SpreadControls from '../components/spread/SpreadControls.astro';
import SpreadReveal from '../components/spread/SpreadReveal.astro';

const allCards = await getCollection('tarotCards');
const cards = allCards.filter((c) => c.data.members.length > 0);
---

<BaseLayout title="A Reading — Poké-Arcana" description="Draw a spread from the Poké-Arcana.">
  <section class="reading pa-rise">
    <p class="reading__kicker">Consult the Oracle</p>
    <h1 class="reading__title">A Reading</h1>
    <p class="reading__lede">
      Focus your intent, then draw your cards and let the oracle answer.
    </p>

    <QuestionChips />

    <div data-spread-section hidden class="spread-section">
      <SpreadControls />
      <SpreadReveal cards={cards} />
    </div>
  </section>
</BaseLayout>

<script>
  // Reveal the spread once a question is set; never re-hide once a reading has begun.
  let revealed = false;
  window.addEventListener('question-change', (e) => {
    if (revealed) return;
    const question = (e as CustomEvent<{ question: string }>).detail?.question ?? '';
    if (!question) return;
    const section = document.querySelector<HTMLElement>('[data-spread-section]');
    if (!section) return;
    section.hidden = false;
    section.classList.add('spread-section--entering');
    revealed = true;
  });
</script>

<style>
  .reading {
    padding: 52px 0 80px;
    text-align: center;
  }
  .reading__kicker {
    margin: 0 0 14px;
    font-family: 'Cinzel', serif;
    font-size: 12px;
    letter-spacing: 0.4em;
    text-transform: uppercase;
    color: #a78bfa;
  }
  .reading__title {
    margin: 0;
    font-family: 'Cinzel Decorative', serif;
    font-weight: 700;
    font-size: clamp(38px, 5vw, 58px);
    color: #f3dfa2;
  }
  .reading__lede {
    max-width: 520px;
    margin: 16px auto 0;
    font-size: 17px;
    line-height: 1.6;
    color: #c8bfe0;
  }

  .spread-section {
    margin-top: 0;
  }
  .spread-section--entering {
    animation: spread-rise 0.6s cubic-bezier(0.22, 1, 0.36, 1) both;
  }
  @keyframes spread-rise {
    from { opacity: 0; transform: translateY(18px); }
    to   { opacity: 1; transform: translateY(0); }
  }
</style>
