---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import SpreadControls from '../components/spread/SpreadControls.astro';
import SpreadReveal from '../components/spread/SpreadReveal.astro';

const allCards = await getCollection('tarotCards');
const cards = allCards.filter((c) => c.data.members.length > 0);
---

<BaseLayout title="A Reading — Poké-Arcana" description="Draw a spread from the Poké-Arcana.">
  <section class="reading pa-rise">
    <p class="reading__kicker">Consult the Oracle</p>
    <h1 class="reading__title">A Reading</h1>
    <p class="reading__lede">
      Still your mind and choose a spread, then draw your cards from the fanned deck below. Turn each card to see
      which Pokémon answers.
    </p>

    <SpreadControls />
    <SpreadReveal cards={cards} />
  </section>
</BaseLayout>

<style>
  .reading {
    padding: 52px 0 80px;
    text-align: center;
  }
  .reading__kicker {
    margin: 0 0 14px;
    font-family: 'Cinzel', serif;
    font-size: 12px;
    letter-spacing: 0.4em;
    text-transform: uppercase;
    color: #a78bfa;
  }
  .reading__title {
    margin: 0;
    font-family: 'Cinzel Decorative', serif;
    font-weight: 700;
    font-size: clamp(38px, 5vw, 58px);
    color: #f3dfa2;
  }
  .reading__lede {
    max-width: 520px;
    margin: 16px auto 0;
    font-size: 17px;
    line-height: 1.6;
    color: #c8bfe0;
  }
</style>
