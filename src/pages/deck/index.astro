---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import DeckGrid from '../../components/DeckGrid.astro';

const cards = await getCollection('pokemonCards');
const sorted = cards.sort((a, b) => a.data.id - b.data.id);
---

<BaseLayout title="The Deck — Poké-Arcana" description="Every Pokémon of Gen 1, drawn as a tarot card.">
  <header class="mb-10">
    <h1 class="font-display text-4xl text-gilt">The Deck</h1>
    <p class="mt-3 max-w-2xl text-mist">
      One hundred fifty-one creatures, each dealt a place in the arcana. Filter by the Major Arcana or by suit, or
      wander the full spread.
    </p>
    <p class="mt-2 text-sm text-mist/70">{sorted.length} cards</p>
  </header>

  <DeckGrid cards={sorted} />
</BaseLayout>
