---
export const prerender = true;

import type { GetStaticPaths } from 'astro';
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import TarotCard from '../../components/TarotCard.astro';
import { SUIT_META, TYPE_COLOR, ROMAN, uiAccent, arcanaMeaning } from '../../lib/arcana/meanings';
import { arcanaMetadata } from '../../lib/arcana/tarot-metadata';
import { slugForArcana } from '../../lib/arcana/index';

export const getStaticPaths = (async () => {
  const cards = await getCollection('pokemonCards');
  return cards.map((entry) => ({
    params: { slug: entry.data.slug },
    props: { card: entry.data },
  }));
}) satisfies GetStaticPaths;

const { card } = Astro.props;
const { arcana } = card;

const accent = uiAccent(arcana);
const isMajor = arcana.kind === 'major';

const paddedId = String(card.id).padStart(3, '0');
const kicker = isMajor ? (ROMAN[arcana.majorNumber ?? 0] ?? '✦') : (SUIT_META[arcana.suit ?? 'cups']?.glyph ?? '✦');
const arcanaLabel = isMajor ? 'Major Arcana' : `Minor Arcana · ${arcana.suit}`;
const arcanaKind = isMajor ? 'Major' : arcana.suit;
const meaning = arcanaMeaning(arcana);
const accentBorder = `color-mix(in srgb, ${accent} 40%, transparent)`;

const meta = arcanaMetadata(arcana);
const cardHref = '/card/' + slugForArcana(arcana);
const rarity = card.isMythical ? 'Mythical' : card.isLegendary ? 'Legendary' : null;
---

<BaseLayout title={`${card.name} — Poké-Arcana`} description={`${card.name}, the ${arcana.name} of the Poké-Arcana.`}>
  <section class="pa-rise pa-detail">
    <a href="/deck" class="pa-back">← Back to the deck</a>

    <div class="pa-grid">
      <div class="pa-left">
        <TarotCard card={card} />
      </div>

      <div class="pa-right">
        <div class="pa-idrow">
          <span>№ {paddedId}</span>
          <span class="pa-sep">·</span>
          <span>{card.genus}</span>
          {rarity && (
            <span class="pa-rarity" style={`border-color:${accentBorder}; color:${accent};`}>{rarity}</span>
          )}
        </div>

        <h1 class="pa-name">{card.name}</h1>

        <a class="pa-arcanabox pa-arcanabox-link" href={cardHref} style={`border-color:${accentBorder};`}>
          <div class="pa-watermark" style={`color:${accent};`}>{kicker}</div>
          <p class="pa-arcanalabel">{arcanaLabel}</p>
          <p class="pa-arcananame" style={`color:${accent};`}>{arcana.name}</p>
          {
            meta && meta.keywords.length > 0 && (
              <div class="pa-arcanakeywords">
                {meta.keywords.slice(0, 5).map((kw) => (
                  <span class="pa-arcanakeyword">{kw}</span>
                ))}
              </div>
            )
          }
          <p class="pa-meaning">{meta?.uprightMeaning ?? meaning}</p>
          <span class="pa-arcanacta" style={`color:${accent};`}>View the {arcana.name} card →</span>
        </a>

        <div class="pa-types">
          {
            card.types.map((t) => (
              <span
                class="pa-type"
                style={`background: color-mix(in srgb, ${TYPE_COLOR[t] ?? '#888'} 82%, black);`}
              >
                {t}
              </span>
            ))
          }
        </div>

        <p class="pa-flavor">{card.flavorText}</p>

        <div class="pa-stats">
          <div>
            <div class="pa-statlabel">Base Stat Total</div>
            <div class="pa-statval" style="color:#e3cf95;">{card.bst}</div>
          </div>
          <div>
            <div class="pa-statlabel">Arcana</div>
            <div class="pa-statval pa-statval-cap" style={`color:${accent};`}>{arcanaKind}</div>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  @keyframes pa-rise {
    from { opacity: 0; transform: translateY(14px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .pa-rise { animation: pa-rise 0.5s ease both; }

  .pa-detail { padding: 36px 0 80px; }

  .pa-back {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    text-decoration: none;
    font-family: 'Cinzel', serif;
    font-size: 12px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #8f86ac;
  }

  .pa-grid {
    display: grid;
    grid-template-columns: 340px 1fr;
    gap: 52px;
    margin-top: 28px;
    align-items: start;
  }

  .pa-left {
    position: sticky;
    top: 100px;
  }

  .pa-idrow {
    display: flex;
    align-items: center;
    gap: 14px;
    font-family: 'Cinzel', serif;
    font-size: 12px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #8f86ac;
  }
  .pa-sep { opacity: 0.5; }
  .pa-rarity {
    padding: 3px 12px;
    border-radius: 999px;
    border: 1px solid transparent;
    font-family: 'Cinzel', serif;
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .pa-name {
    font-family: 'Cinzel Decorative', serif;
    font-weight: 700;
    font-size: clamp(40px, 5vw, 60px);
    margin: 10px 0 0;
    color: #f3dfa2;
    text-transform: capitalize;
  }

  .pa-arcanabox {
    margin-top: 22px;
    padding: 22px 24px;
    border-radius: 14px;
    border: 1px solid transparent;
    background: linear-gradient(160deg, rgba(21, 14, 43, 0.7), rgba(11, 7, 20, 0.5));
    position: relative;
    overflow: hidden;
  }
  .pa-arcanabox-link {
    display: block;
    text-decoration: none;
    transition: border-color 0.2s, transform 0.2s;
  }
  .pa-arcanabox-link:hover {
    border-color: color-mix(in srgb, #a78bfa 55%, transparent);
    transform: translateY(-2px);
  }
  .pa-watermark {
    position: absolute;
    top: -30px;
    right: -20px;
    font-size: 120px;
    opacity: 0.06;
    font-family: 'Cinzel Decorative', serif;
  }
  .pa-arcanakeywords {
    display: flex;
    flex-wrap: wrap;
    gap: 7px;
    margin-top: 14px;
  }
  .pa-arcanakeyword {
    padding: 4px 11px;
    border-radius: 999px;
    font-family: 'Cinzel', serif;
    font-size: 10px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #c8bfe0;
    background: rgba(11, 7, 20, 0.45);
    border: 1px solid rgba(167, 139, 250, 0.18);
  }
  .pa-arcanacta {
    display: inline-block;
    margin-top: 16px;
    font-family: 'Cinzel', serif;
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }
  .pa-arcanalabel {
    margin: 0;
    font-family: 'Cinzel', serif;
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: #8f86ac;
  }
  .pa-arcananame {
    margin: 8px 0 0;
    font-family: 'Cinzel', serif;
    font-weight: 600;
    font-size: 30px;
  }
  .pa-meaning {
    margin: 14px 0 0;
    font-size: 16px;
    line-height: 1.6;
    color: #c8bfe0;
    font-style: italic;
  }

  .pa-types {
    display: flex;
    flex-wrap: wrap;
    gap: 9px;
    margin-top: 22px;
  }
  .pa-type {
    padding: 6px 16px;
    border-radius: 999px;
    font-family: 'Cinzel', serif;
    font-size: 11.5px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #fff;
  }

  .pa-flavor {
    margin: 24px 0 0;
    font-size: 18px;
    line-height: 1.7;
    color: #d8d0ec;
    max-width: 560px;
  }

  .pa-stats {
    display: flex;
    gap: 40px;
    margin-top: 28px;
    padding-top: 24px;
    border-top: 1px solid rgba(203, 168, 90, 0.18);
  }
  .pa-statlabel {
    font-family: 'Cinzel', serif;
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #8f86ac;
  }
  .pa-statval {
    font-family: 'Cinzel Decorative', serif;
    font-weight: 700;
    font-size: 38px;
    margin-top: 4px;
  }
  .pa-statval-cap { text-transform: capitalize; }

  @media (max-width: 720px) {
    .pa-grid {
      grid-template-columns: 1fr;
      gap: 32px;
    }
    .pa-left {
      position: static;
      justify-self: center;
    }
  }
</style>
