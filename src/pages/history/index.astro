---
export const prerender = true;

import BaseLayout from '../../layouts/BaseLayout.astro';
import '../../styles/reading.css';
import '../../styles/natal-reading.css';
import '../../styles/numerology-reading.css';
---

<BaseLayout title="My Readings — Poké-Arcana" description="Revisit your past Poké-Arcana readings.">
  <section class="history pa-rise">
    <p class="history__kicker">Kept For You</p>
    <h1 class="history__title">My Readings</h1>
    <p class="history__note">
      Saved only in this browser — private to you, and gone if you clear your data or switch device.
    </p>

    <div data-history-root class="history__root"></div>

    <template data-empty>
      <div class="history-empty">
        <p class="history-empty__text">You have no saved draws yet.</p>
        <a href="/reading" class="history-empty__cta">Consult the Oracle</a>
      </div>
    </template>

    <template data-empty-natal>
      <div class="history-empty">
        <p class="history-empty__text">You have no saved star charts yet.</p>
        <a href="/star-map" class="history-empty__cta">Find Your Signs</a>
      </div>
    </template>

    <template data-empty-numerology>
      <div class="history-empty">
        <p class="history-empty__text">You have no saved numerology readings yet.</p>
        <a href="/numerology" class="history-empty__cta">Find Your Numbers</a>
      </div>
    </template>
  </section>
</BaseLayout>

<script>
  import { listDraws, getDraw } from '../../lib/history';
  import { renderAiReading, renderTemplateReading } from '../../lib/reading-render';
  import { listNatalReadings, getNatalReading, type NatalReadingRecord } from '../../lib/natal-history';
  import { renderNatalReading, renderNatalSynthesis } from '../../lib/natal-render';
  import { listNumerologyReadings, getNumerologyReading, type NumerologyReadingRecord } from '../../lib/numerology-history';
  import { renderNumerologyReading, renderNumerologyWeave } from '../../lib/numerology-render';

  const root = document.querySelector<HTMLElement>('[data-history-root]');
  const emptyTpl = document.querySelector<HTMLTemplateElement>('[data-empty]');
  const emptyNatalTpl = document.querySelector<HTMLTemplateElement>('[data-empty-natal]');
  const emptyNumerologyTpl = document.querySelector<HTMLTemplateElement>('[data-empty-numerology]');
  if (root && emptyTpl && emptyNatalTpl && emptyNumerologyTpl) {
    const params = new URLSearchParams(window.location.search);
    const id = params.get('id');
    const natalId = params.get('natalId');
    const numerologyId = params.get('numerologyId');
    if (id) renderDetail(id, root, emptyTpl);
    else if (natalId) renderNatalDetail(natalId, root, emptyNatalTpl);
    else if (numerologyId) renderNumerologyDetail(numerologyId, root, emptyNumerologyTpl);
    else renderOverview(root, emptyTpl, emptyNatalTpl, emptyNumerologyTpl);
  }

  function showEmpty(root: HTMLElement, emptyTpl: HTMLTemplateElement) {
    root.replaceChildren(emptyTpl.content.cloneNode(true));
  }

  function formatDate(ms: number): string {
    try {
      return new Date(ms).toLocaleString(undefined, {
        year: 'numeric', month: 'short', day: 'numeric',
        hour: 'numeric', minute: '2-digit',
      });
    } catch {
      return '';
    }
  }

  function sectionHeading(text: string): HTMLElement {
    const h2 = document.createElement('h2');
    h2.className = 'history-section__title';
    h2.textContent = text;
    return h2;
  }

  function birthSummary(birth: NatalReadingRecord['birth']): string {
    const [y, m, d] = birth.date.split('-').map(Number);
    let dateStr: string;
    try {
      dateStr = new Date(y, m - 1, d).toLocaleDateString(undefined, {
        year: 'numeric', month: 'long', day: 'numeric',
      });
    } catch {
      dateStr = birth.date;
    }
    return birth.city ? `${dateStr} · ${birth.city.label}` : dateStr;
  }

  function numerologyBirthSummary(birth: NumerologyReadingRecord['birth']): string {
    try {
      return new Date(birth.year, birth.month - 1, birth.day).toLocaleDateString(undefined, {
        year: 'numeric', month: 'long', day: 'numeric',
      });
    } catch {
      return `${birth.year}-${birth.month}-${birth.day}`;
    }
  }

  function renderOverview(
    root: HTMLElement, emptyTpl: HTMLTemplateElement, emptyNatalTpl: HTMLTemplateElement,
    emptyNumerologyTpl: HTMLTemplateElement,
  ) {
    const draws = listDraws();
    const readings = listNatalReadings();
    const numerologyReadings = listNumerologyReadings();

    const drawsSection = document.createElement('section');
    drawsSection.className = 'history-section';
    drawsSection.appendChild(sectionHeading('My Draws'));
    drawsSection.appendChild(draws.length ? buildDrawsList(draws) : emptyTpl.content.cloneNode(true));

    const natalSection = document.createElement('section');
    natalSection.className = 'history-section';
    natalSection.appendChild(sectionHeading('My Star Charts'));
    natalSection.appendChild(
      readings.length ? buildNatalList(readings) : emptyNatalTpl.content.cloneNode(true),
    );

    const numerologySection = document.createElement('section');
    numerologySection.className = 'history-section';
    numerologySection.appendChild(sectionHeading('My Numerology Readings'));
    numerologySection.appendChild(
      numerologyReadings.length
        ? buildNumerologyList(numerologyReadings)
        : emptyNumerologyTpl.content.cloneNode(true),
    );

    root.replaceChildren(drawsSection, natalSection, numerologySection);
  }

  function buildDrawsList(draws: ReturnType<typeof listDraws>): HTMLElement {
    const list = document.createElement('ul');
    list.className = 'history-list';

    for (const draw of draws) {
      const item = document.createElement('li');
      item.className = 'history-item';

      const link = document.createElement('a');
      link.className = 'history-item__link';
      link.href = `/history/?id=${encodeURIComponent(draw.id)}`;

      const q = document.createElement('p');
      q.className = 'history-item__question';
      q.textContent = draw.question ? `"${draw.question}"` : 'An unspoken question';

      const meta = document.createElement('div');
      meta.className = 'history-item__meta';

      const date = document.createElement('span');
      date.className = 'history-item__date';
      date.textContent = formatDate(draw.createdAt);
      meta.appendChild(date);

      const spreadBadge = document.createElement('span');
      spreadBadge.className = 'history-item__badge';
      spreadBadge.textContent = draw.spreadSize === 1 ? '1 card' : `${draw.spreadSize} cards`;
      meta.appendChild(spreadBadge);

      if (draw.ai) {
        const aiBadge = document.createElement('span');
        aiBadge.className = 'history-item__badge history-item__badge--ai';
        aiBadge.textContent = 'AI reading';
        meta.appendChild(aiBadge);
      }

      const cardList = document.createElement('ul');
      cardList.className = 'history-item__cards';
      for (const card of draw.cards) {
        const chip = document.createElement('li');
        chip.className = 'history-item__card-chip';

        const pos = document.createElement('span');
        pos.className = 'history-item__card-position';
        pos.textContent = card.position;

        const name = document.createElement('span');
        name.className = 'history-item__card-name';
        name.textContent = card.arcanaName;

        chip.append(pos, name);
        cardList.appendChild(chip);
      }

      link.append(q, meta, cardList);
      item.appendChild(link);
      list.appendChild(item);
    }

    return list;
  }

  function buildNatalList(readings: NatalReadingRecord[]): HTMLElement {
    const list = document.createElement('ul');
    list.className = 'history-list';

    for (const reading of readings) {
      const item = document.createElement('li');
      item.className = 'history-item';

      const link = document.createElement('a');
      link.className = 'history-item__link';
      link.href = `/history/?natalId=${encodeURIComponent(reading.id)}`;

      const q = document.createElement('p');
      q.className = 'history-item__question';
      q.textContent = birthSummary(reading.birth);

      const meta = document.createElement('div');
      meta.className = 'history-item__meta';

      const date = document.createElement('span');
      date.className = 'history-item__date';
      date.textContent = formatDate(reading.createdAt);
      meta.appendChild(date);

      if (reading.synthesis) {
        const aiBadge = document.createElement('span');
        aiBadge.className = 'history-item__badge history-item__badge--ai';
        aiBadge.textContent = 'AI reading';
        meta.appendChild(aiBadge);
      }

      const cardList = document.createElement('ul');
      cardList.className = 'history-item__cards';
      const bigThree = reading.points.filter((p) => p.label === 'Sun' || p.label === 'Moon' || p.label === 'Rising');
      for (const point of bigThree) {
        const chip = document.createElement('li');
        chip.className = 'history-item__card-chip';

        const pos = document.createElement('span');
        pos.className = 'history-item__card-position';
        pos.textContent = point.label;

        const name = document.createElement('span');
        name.className = 'history-item__card-name';
        name.textContent = point.cardName;

        chip.append(pos, name);
        cardList.appendChild(chip);
      }

      link.append(q, meta, cardList);
      item.appendChild(link);
      list.appendChild(item);
    }

    return list;
  }

  function buildNumerologyList(readings: NumerologyReadingRecord[]): HTMLElement {
    const list = document.createElement('ul');
    list.className = 'history-list';

    for (const reading of readings) {
      const item = document.createElement('li');
      item.className = 'history-item';

      const link = document.createElement('a');
      link.className = 'history-item__link';
      link.href = `/history/?numerologyId=${encodeURIComponent(reading.id)}`;

      const q = document.createElement('p');
      q.className = 'history-item__question';
      q.textContent = reading.name;

      const meta = document.createElement('div');
      meta.className = 'history-item__meta';

      const date = document.createElement('span');
      date.className = 'history-item__date';
      date.textContent = numerologyBirthSummary(reading.birth);
      meta.appendChild(date);

      const lifePathBadge = document.createElement('span');
      lifePathBadge.className = 'history-item__badge';
      lifePathBadge.textContent = `Life Path ${reading.numbers.lifePath}`;
      meta.appendChild(lifePathBadge);

      if (reading.weave) {
        const aiBadge = document.createElement('span');
        aiBadge.className = 'history-item__badge history-item__badge--ai';
        aiBadge.textContent = 'AI reading';
        meta.appendChild(aiBadge);
      }

      link.append(q, meta);
      item.appendChild(link);
      list.appendChild(item);
    }

    return list;
  }

  function renderDetail(id: string, root: HTMLElement, emptyTpl: HTMLTemplateElement) {
    const draw = getDraw(id);
    if (!draw) {
      showEmpty(root, emptyTpl);
      return;
    }

    const back = document.createElement('a');
    back.className = 'history-back';
    back.href = '/history/';
    back.textContent = '← All draws';

    const templatePanel = document.createElement('div');
    templatePanel.className = 'reading-panel';
    templatePanel.appendChild(
      renderTemplateReading({ question: draw.question, spreadSize: draw.spreadSize, cards: draw.cards })
    );

    root.replaceChildren(back, templatePanel);

    if (draw.ai) {
      const aiPanel = document.createElement('div');
      aiPanel.className = 'ai-reading-panel';
      aiPanel.appendChild(renderAiReading(draw.ai));
      root.appendChild(aiPanel);
    }
  }

  function renderNatalDetail(id: string, root: HTMLElement, emptyTpl: HTMLTemplateElement) {
    const reading = getNatalReading(id);
    if (!reading) {
      showEmpty(root, emptyTpl);
      return;
    }

    const back = document.createElement('a');
    back.className = 'history-back';
    back.href = '/history/';
    back.textContent = '← All readings';

    const header = document.createElement('div');
    header.className = 'natal-detail-header';

    const kicker = document.createElement('p');
    kicker.className = 'natal-detail-header__kicker';
    kicker.textContent = '✦ Your Star Chart ✦';

    const summary = document.createElement('p');
    summary.className = 'natal-detail-header__summary';
    summary.textContent = birthSummary(reading.birth);

    const saved = document.createElement('p');
    saved.className = 'natal-detail-header__date';
    saved.textContent = `Saved ${formatDate(reading.createdAt)}`;

    header.append(kicker, summary, saved);

    const panel = document.createElement('div');
    panel.className = 'reading-panel';
    panel.appendChild(renderNatalReading(reading.points));

    root.replaceChildren(back, header, panel);

    if (reading.synthesis) {
      const synthesisPanel = document.createElement('div');
      synthesisPanel.className = 'ai-reading-panel';
      synthesisPanel.appendChild(renderNatalSynthesis(reading.synthesis));
      root.appendChild(synthesisPanel);
    }
  }

  function renderNumerologyDetail(id: string, root: HTMLElement, emptyTpl: HTMLTemplateElement) {
    const reading = getNumerologyReading(id);
    if (!reading) {
      showEmpty(root, emptyTpl);
      return;
    }

    const back = document.createElement('a');
    back.className = 'history-back';
    back.href = '/history/';
    back.textContent = '← All numerology readings';

    const header = document.createElement('div');
    header.className = 'natal-detail-header';

    const kicker = document.createElement('p');
    kicker.className = 'natal-detail-header__kicker';
    kicker.textContent = '✦ Your Numbers ✦';

    const summary = document.createElement('p');
    summary.className = 'natal-detail-header__summary';
    summary.textContent = `${reading.name} — ${numerologyBirthSummary(reading.birth)}`;

    const saved = document.createElement('p');
    saved.className = 'natal-detail-header__date';
    saved.textContent = `Saved ${formatDate(reading.createdAt)}`;

    header.append(kicker, summary, saved);

    const panel = document.createElement('div');
    panel.className = 'reading-panel';
    panel.appendChild(renderNumerologyReading(reading));

    root.replaceChildren(back, header, panel);

    if (reading.weave) {
      const weavePanel = document.createElement('div');
      weavePanel.className = 'ai-reading-panel';
      weavePanel.appendChild(renderNumerologyWeave(reading.weave));
      root.appendChild(weavePanel);
    }
  }
</script>

<style is:global>
  .history {
    padding: 52px 0 80px;
    text-align: center;
  }
  .history__kicker {
    margin: 0 0 14px;
    font-family: 'Cinzel', serif;
    font-size: 12px;
    letter-spacing: 0.4em;
    text-transform: uppercase;
    color: #a78bfa;
  }
  .history__title {
    margin: 0;
    font-family: 'Cinzel Decorative', serif;
    font-weight: 700;
    font-size: clamp(38px, 5vw, 58px);
    color: #f3dfa2;
  }
  .history__note {
    max-width: 520px;
    margin: 16px auto 0;
    font-family: 'EB Garamond', serif;
    font-style: italic;
    font-size: 15px;
    line-height: 1.6;
    color: #8f86ac;
  }
  .history__root {
    margin-top: 44px;
  }

  .history-section {
    text-align: left;
  }
  .history-section + .history-section {
    margin-top: 56px;
    padding-top: 44px;
    border-top: 1px solid rgba(203, 168, 90, 0.16);
  }
  .history-section__title {
    margin: 0 0 22px;
    text-align: center;
    font-family: 'Cinzel', serif;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: #cba85a;
  }

  .natal-detail-header {
    max-width: 680px;
    margin: 0 auto 8px;
    text-align: center;
  }
  .natal-detail-header__kicker {
    margin: 0 0 10px;
    font-family: 'Cinzel', serif;
    font-size: 11px;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: #a78bfa;
  }
  .natal-detail-header__summary {
    margin: 0;
    font-family: 'Cinzel Decorative', serif;
    font-size: clamp(18px, 2.5vw, 24px);
    font-weight: 700;
    color: #f3dfa2;
  }
  .natal-detail-header__date {
    margin: 10px 0 0;
    font-family: 'EB Garamond', serif;
    font-style: italic;
    font-size: 14px;
    color: #8f86ac;
  }

  .history-list {
    list-style: none;
    margin: 0 auto;
    padding: 0;
    max-width: 680px;
    display: flex;
    flex-direction: column;
    gap: 16px;
    text-align: left;
  }
  .history-item__link {
    display: block;
    padding: 20px 24px;
    border-radius: 12px;
    border: 1px solid rgba(203, 168, 90, 0.2);
    background: rgba(124, 92, 255, 0.05);
    text-decoration: none;
    transition: border-color 0.25s, transform 0.2s, background 0.25s;
  }
  .history-item__link:hover {
    transform: translateY(-2px);
    border-color: rgba(203, 168, 90, 0.5);
    background: rgba(124, 92, 255, 0.1);
  }
  .history-item__question {
    margin: 0 0 8px;
    font-family: 'Cinzel Decorative', serif;
    font-weight: 700;
    font-size: 18px;
    color: #f3dfa2;
    line-height: 1.3;
  }
  .history-item__meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 8px;
    margin: 0 0 14px;
  }
  .history-item__date {
    font-family: 'EB Garamond', serif;
    font-style: italic;
    font-size: 13px;
    color: #8f86ac;
  }
  .history-item__badge {
    padding: 3px 10px;
    border-radius: 999px;
    border: 1px solid rgba(167, 139, 250, 0.35);
    font-family: 'Cinzel', serif;
    font-size: 9px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #a78bfa;
  }
  .history-item__badge--ai {
    border-color: rgba(227, 207, 149, 0.5);
    color: #e3cf95;
  }
  .history-item__cards {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .history-item__card-chip {
    display: flex;
    align-items: baseline;
    gap: 6px;
    padding: 6px 12px;
    border-radius: 8px;
    background: rgba(11, 7, 20, 0.4);
    border: 1px solid rgba(203, 168, 90, 0.15);
  }
  .history-item__card-position {
    font-family: 'Cinzel', serif;
    font-size: 9px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #6f6690;
  }
  .history-item__card-name {
    font-family: 'EB Garamond', serif;
    font-size: 14px;
    color: #c8bfe0;
  }

  .history-empty {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
    padding: 40px 0;
  }
  .history-empty__text {
    margin: 0;
    font-family: 'EB Garamond', serif;
    font-style: italic;
    font-size: 18px;
    color: #c8bfe0;
  }
  .history-empty__cta {
    padding: 13px 34px;
    border-radius: 999px;
    font-family: 'Cinzel', serif;
    font-size: 12px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #0b0714;
    text-decoration: none;
    background: linear-gradient(160deg, #e3cf95, #c39a45);
    transition: transform 0.2s;
  }
  .history-empty__cta:hover {
    transform: translateY(-1px);
  }

  .history-back {
    display: inline-block;
    margin-bottom: 8px;
    font-family: 'Cinzel', serif;
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #a78bfa;
    text-decoration: none;
  }
  .history-back:hover {
    color: #e3cf95;
  }

  @media (max-width: 640px) {
    .history {
      padding: 36px 0 56px;
    }
    .history-item__link {
      padding: 16px 18px;
    }
    .history-item__question {
      font-size: 16px;
    }
    .history-item__card-chip {
      padding: 5px 10px;
    }
    .history-item__card-name {
      font-size: 13px;
    }
  }
</style>
