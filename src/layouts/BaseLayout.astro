---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const { title = 'Poké-Arcana', description = 'A tarot deck divined from Pokémon.' } = Astro.props;
const path = Astro.url.pathname;
const isActive = (href: string) => path === href || (href !== '/' && path.startsWith(href));
const navPill = (active: boolean) =>
  active
    ? 'color:#0b0714; background:linear-gradient(160deg,#e3cf95,#c39a45);'
    : 'color:#c8bfe0; background:transparent;';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;500;600;700&family=Cinzel+Decorative:wght@400;700;900&family=EB+Garamond:ital,wght@0,400;0,500;0,600;1,400&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body>
    <div class="starfield" aria-hidden="true"></div>

    <header class="site-header">
      <nav class="site-nav">
        <a href="/" class="brand">
          <span class="brand__mark">✦</span>
          <span class="brand__name">Poké&#8209;Arcana</span>
        </a>
        <div class="site-nav__links">
          <a href="/deck" class="nav-pill" style={navPill(isActive('/deck'))}>The Deck</a>
          <a href="/reading" class="nav-pill" style={navPill(isActive('/reading'))}>A Reading</a>
          <a href="/star-map" class="nav-pill" style={navPill(isActive('/star-map'))}>The Stars</a>
          <a href="/numerology" class="nav-pill" style={navPill(isActive('/numerology'))}>The Numbers</a>
          <a href="/history" class="nav-pill" style={navPill(isActive('/history'))}>My Draws</a>
        </div>
      </nav>
    </header>

    <main class="site-main">
      <slot />
    </main>

    <footer class="site-footer">
      <p>
        Card data from <a href="https://pokeapi.co" target="_blank" rel="noopener">PokéAPI</a>. Pokémon © Nintendo /
        Game Freak. A fan divination.
      </p>
    </footer>
  </body>
</html>

<style>
  .starfield {
    position: fixed;
    inset: 0;
    pointer-events: none;
    opacity: 0.7;
    z-index: 0;
    /* Accent stars — larger, colored, hand-placed. */
    background-image:
      radial-gradient(1.4px 1.4px at 20% 30%, #cba85a 50%, transparent),
      radial-gradient(1.4px 1.4px at 70% 20%, #a78bfa 50%, transparent),
      radial-gradient(1.4px 1.4px at 40% 70%, #e3cf95 50%, transparent),
      radial-gradient(1.4px 1.4px at 85% 60%, #c3b6d8 50%, transparent),
      radial-gradient(1.4px 1.4px at 55% 45%, #cba85a 50%, transparent),
      radial-gradient(1.4px 1.4px at 10% 80%, #a78bfa 50%, transparent),
      radial-gradient(1.4px 1.4px at 92% 88%, #e3cf95 50%, transparent),
      radial-gradient(1.4px 1.4px at 33% 12%, #e3cf95 50%, transparent),
      radial-gradient(1.4px 1.4px at 62% 8%, #c3b6d8 50%, transparent),
      radial-gradient(1.4px 1.4px at 8% 15%, #cba85a 50%, transparent),
      radial-gradient(1.4px 1.4px at 48% 90%, #a78bfa 50%, transparent),
      radial-gradient(1.4px 1.4px at 78% 78%, #cba85a 50%, transparent),
      radial-gradient(1.4px 1.4px at 25% 55%, #c3b6d8 50%, transparent),
      radial-gradient(1.4px 1.4px at 88% 35%, #e3cf95 50%, transparent),
      radial-gradient(1.4px 1.4px at 5% 45%, #a78bfa 50%, transparent),
      radial-gradient(1.4px 1.4px at 66% 62%, #cba85a 50%, transparent);
    background-size: 100% 100%;
  }
  /* Two dense tiled dust layers of tiny stars — different tile sizes so the
     pattern never obviously repeats. */
  .starfield::before,
  .starfield::after {
    content: '';
    position: absolute;
    inset: 0;
  }
  .starfield::before {
    background-image:
      radial-gradient(1px 1px at 12% 18%, #ffffff 50%, transparent),
      radial-gradient(1px 1px at 37% 62%, #ffffff 50%, transparent),
      radial-gradient(1px 1px at 71% 24%, #e3cf95 50%, transparent),
      radial-gradient(1px 1px at 88% 71%, #ffffff 50%, transparent),
      radial-gradient(1px 1px at 22% 84%, #c3b6d8 50%, transparent),
      radial-gradient(1px 1px at 54% 8%, #ffffff 50%, transparent),
      radial-gradient(1px 1px at 6% 55%, #ffffff 50%, transparent),
      radial-gradient(1px 1px at 46% 38%, #a78bfa 50%, transparent),
      radial-gradient(1px 1px at 82% 12%, #ffffff 50%, transparent),
      radial-gradient(1px 1px at 30% 95%, #ffffff 50%, transparent),
      radial-gradient(1px 1px at 64% 48%, #ffffff 50%, transparent),
      radial-gradient(1px 1px at 96% 42%, #cba85a 50%, transparent);
    background-size: 260px 260px;
    background-repeat: repeat;
    opacity: 0.55;
  }
  .starfield::after {
    background-image:
      radial-gradient(0.7px 0.7px at 15% 40%, #ffffff 50%, transparent),
      radial-gradient(0.7px 0.7px at 42% 12%, #ffffff 50%, transparent),
      radial-gradient(0.7px 0.7px at 68% 78%, #ffffff 50%, transparent),
      radial-gradient(0.7px 0.7px at 91% 22%, #ffffff 50%, transparent),
      radial-gradient(0.7px 0.7px at 8% 88%, #ffffff 50%, transparent),
      radial-gradient(0.7px 0.7px at 55% 58%, #ffffff 50%, transparent),
      radial-gradient(0.7px 0.7px at 33% 72%, #ffffff 50%, transparent),
      radial-gradient(0.7px 0.7px at 78% 34%, #ffffff 50%, transparent),
      radial-gradient(0.7px 0.7px at 24% 26%, #ffffff 50%, transparent),
      radial-gradient(0.7px 0.7px at 60% 92%, #ffffff 50%, transparent),
      radial-gradient(0.7px 0.7px at 4% 8%, #ffffff 50%, transparent),
      radial-gradient(0.7px 0.7px at 88% 62%, #ffffff 50%, transparent);
    background-size: 170px 170px;
    background-repeat: repeat;
    opacity: 0.4;
  }

  .site-header {
    position: sticky;
    top: 0;
    z-index: 40;
    backdrop-filter: blur(8px);
    background: linear-gradient(180deg, rgba(11, 7, 20, 0.9), rgba(11, 7, 20, 0.4));
    border-bottom: 1px solid rgba(203, 168, 90, 0.18);
  }
  .site-nav {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 18px 28px;
  }
  .brand {
    display: flex;
    align-items: center;
    gap: 11px;
    text-decoration: none;
  }
  .brand__mark {
    display: inline-flex;
    width: 30px;
    height: 30px;
    align-items: center;
    justify-content: center;
    border: 1px solid rgba(203, 168, 90, 0.55);
    border-radius: 50%;
    color: #cba85a;
    font-size: 14px;
  }
  .brand__name {
    font-family: 'Cinzel Decorative', serif;
    font-weight: 700;
    font-size: 19px;
    letter-spacing: 0.06em;
    color: #e3cf95;
  }
  .site-nav__links {
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .nav-pill {
    padding: 8px 16px;
    border-radius: 999px;
    font-family: 'Cinzel', serif;
    font-size: 12.5px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    text-decoration: none;
    transition: all 0.3s;
  }

  .site-main {
    position: relative;
    z-index: 10;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 28px;
    min-height: 60vh;
  }

  .site-footer {
    position: relative;
    z-index: 10;
    border-top: 1px solid rgba(203, 168, 90, 0.14);
    padding: 30px 28px;
    text-align: center;
  }
  .site-footer p {
    margin: 0;
    font-size: 13px;
    color: #8f86ac;
  }
  .site-footer a {
    color: #cba85a;
  }
  .site-footer a:hover {
    color: #e3cf95;
  }

  @media (max-width: 640px) {
    .site-nav {
      flex-wrap: wrap;
      justify-content: center;
      gap: 12px;
      padding: 14px 16px;
    }
    .site-nav__links {
      flex-wrap: wrap;
      justify-content: center;
      gap: 6px;
    }
    .nav-pill {
      padding: 7px 12px;
      font-size: 11.5px;
    }
    .site-main {
      padding: 0 16px;
    }
    .site-footer {
      padding: 24px 16px;
    }
  }
</style>
