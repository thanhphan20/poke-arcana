---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const { title = 'Poké-Arcana', description = 'A tarot deck divined from Pokémon.' } = Astro.props;
const path = Astro.url.pathname;
const isActive = (href: string) => path === href || (href !== '/' && path.startsWith(href));
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body class="flex min-h-screen flex-col">
    <header class="border-b border-white/5">
      <nav class="mx-auto flex max-w-6xl items-center justify-between px-6 py-5">
        <a href="/" class="font-display text-xl tracking-wide text-gilt">Poké-Arcana</a>
        <div class="flex gap-6 text-sm">
          <a
            href="/deck"
            class:list={['transition hover:text-gilt-soft', isActive('/deck') ? 'text-gilt' : 'text-mist']}
            >The Deck</a
          >
          <a
            href="/reading"
            class:list={['transition hover:text-gilt-soft', isActive('/reading') ? 'text-gilt' : 'text-mist']}
            >A Reading</a
          >
        </div>
      </nav>
    </header>

    <main class="mx-auto w-full max-w-6xl flex-1 px-6 py-10">
      <slot />
    </main>

    <footer class="border-t border-white/5 px-6 py-8 text-center text-xs text-mist/70">
      Card data from <a href="https://pokeapi.co" class="underline hover:text-mist">PokéAPI</a>. Pokémon © Nintendo /
      Game Freak. A fan project.
    </footer>
  </body>
</html>
