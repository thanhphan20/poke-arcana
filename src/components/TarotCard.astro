---
import type { CollectionEntry } from 'astro:content';
import type { ArcanaResult } from '../lib/arcana/types';
import { cardTheme, ROMAN, SUIT_META } from '../lib/arcana/meanings';
import { spriteUrl, SPRITE_FALLBACK } from '../lib/sprites';

type CardData = CollectionEntry<'pokemonCards'>['data'];

interface Props {
  /** Full Pokemon card: renders sprite + name + Pokedex id. */
  card?: CardData;
  /** Face-only mode: renders pure tarot art, no sprite. Used for the 78-card deck grid. */
  arcana?: ArcanaResult;
  href?: string;
  class?: string;
}

const { card, arcana: arcanaProp, href, class: className = '' } = Astro.props;
const arcana = card?.arcana ?? arcanaProp;
if (!arcana) throw new Error('TarotCard requires either `card` or `arcana`.');

const theme = cardTheme(arcana);
const isMajor = arcana.kind === 'major';
const kicker = isMajor ? (ROMAN[arcana.majorNumber ?? 0] ?? '✦') : (SUIT_META[arcana.suit ?? 'cups']?.glyph ?? '✦');
const idLabel = card ? `№ ${String(card.id).padStart(3, '0')}` : null;

const Tag = href ? 'a' : 'div';
---

<Tag
  href={href}
  class:list={['arcana-card', href && 'is-link', className]}
  style={`--accent:${theme.accent}; --wash:${theme.wash};`}
>
  <div class="arcana-card__paper">
    <div class="arcana-card__grain"></div>
    <div class="arcana-card__keyline"></div>
    <span class="arcana-card__flourish" style="top:5px; left:7px;">✦</span>
    <span class="arcana-card__flourish" style="top:5px; right:7px;">✦</span>
    <span class="arcana-card__flourish" style="bottom:5px; left:7px;">✦</span>
    <span class="arcana-card__flourish" style="bottom:5px; right:7px;">✦</span>

    <div class="arcana-card__kicker">{kicker}</div>

    <div class="arcana-card__vignette">
      <div class="arcana-card__rays"></div>
      <div class="arcana-card__horizon"></div>
      {
        card ? (
          <img
            src={spriteUrl(card.id, 'artwork')}
            alt={card.name}
            loading="lazy"
            class="arcana-card__sprite"
            onerror={`this.onerror=null;this.src='${SPRITE_FALLBACK}';`}
          />
        ) : (
          <span class="arcana-card__glyph">{kicker}</span>
        )
      }
    </div>

    <div class="arcana-card__banner">
      <span class="arcana-card__star">✦</span>
      <span class="arcana-card__arcana">{arcana.name}</span>
      <span class="arcana-card__star">✦</span>
    </div>

    <div class="arcana-card__footer">
      <span class="arcana-card__name">{card ? card.name : (isMajor ? 'Major Arcana' : SUIT_META[arcana.suit ?? 'cups'].name)}</span>
      {idLabel && <span class="arcana-card__id">{idLabel}</span>}
    </div>
  </div>
</Tag>

<style>
  .arcana-card__glyph {
    font-size: 64px;
    line-height: 1;
    opacity: 0.55;
    font-family: 'Cinzel Decorative', serif;
  }
</style>
