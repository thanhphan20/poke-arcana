---
import type { CollectionEntry } from 'astro:content';
import { cardTheme, ROMAN, SUIT_META } from '../lib/arcana/meanings';

type CardData = CollectionEntry<'pokemonCards'>['data'];

interface Props {
  card: CardData;
  href?: string;
  class?: string;
}

const { card, href, class: className = '' } = Astro.props;
const { arcana } = card;
const theme = cardTheme(arcana);
const isMajor = arcana.kind === 'major';
const kicker = isMajor ? (ROMAN[arcana.majorNumber ?? 0] ?? '✦') : (arcana.suit ?? '');
const idLabel = `№ ${String(card.id).padStart(3, '0')}`;

const Tag = href ? 'a' : 'div';
---

<Tag
  href={href}
  class:list={['arcana-card', href && 'is-link', className]}
  style={`--accent:${theme.accent}; --wash:${theme.wash};`}
>
  <div class="arcana-card__paper">
    <div class="arcana-card__grain"></div>
    <div class="arcana-card__keyline"></div>
    <span class="arcana-card__flourish" style="top:5px; left:7px;">✦</span>
    <span class="arcana-card__flourish" style="top:5px; right:7px;">✦</span>
    <span class="arcana-card__flourish" style="bottom:5px; left:7px;">✦</span>
    <span class="arcana-card__flourish" style="bottom:5px; right:7px;">✦</span>

    <div class="arcana-card__kicker">{kicker}</div>

    <div class="arcana-card__vignette">
      <div class="arcana-card__rays"></div>
      <div class="arcana-card__horizon"></div>
      <img src={card.sprite} alt={card.name} loading="lazy" class="arcana-card__sprite" />
    </div>

    <div class="arcana-card__banner">
      <span class="arcana-card__star">✦</span>
      <span class="arcana-card__arcana">{arcana.name}</span>
      <span class="arcana-card__star">✦</span>
    </div>

    <div class="arcana-card__footer">
      <span class="arcana-card__name">{card.name}</span>
      <span class="arcana-card__id">{idLabel}</span>
    </div>
  </div>
</Tag>
