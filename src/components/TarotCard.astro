---
import type { CollectionEntry } from 'astro:content';

type CardData = CollectionEntry<'pokemonCards'>['data'];

interface Props {
  card: CardData;
  /** When true, render as a link to the card detail page. */
  href?: string;
  class?: string;
}

const { card, href, class: className = '' } = Astro.props;
const { arcana } = card;

const suitColor: Record<string, string> = {
  cups: 'var(--color-cups)',
  wands: 'var(--color-wands)',
  swords: 'var(--color-swords)',
  pentacles: 'var(--color-pentacles)',
};
const accent = arcana.kind === 'major' ? 'var(--color-gilt)' : suitColor[arcana.suit ?? 'cups'];
const romanNumerals = ['0', 'I', 'II', 'III', 'IV', 'V', 'VI', 'VII', 'VIII', 'IX', 'X', 'XI', 'XII', 'XIII', 'XIV', 'XV', 'XVI', 'XVII', 'XVIII', 'XIX', 'XX', 'XXI'];
const corner =
  arcana.kind === 'major' ? romanNumerals[arcana.majorNumber ?? 0] : `#${String(card.id).padStart(3, '0')}`;

const Tag = href ? 'a' : 'div';
---

<Tag
  href={href}
  class:list={[
    'group relative block overflow-hidden rounded-xl border bg-arcane/60 p-3 shadow-lg shadow-black/40 transition',
    href ? 'hover:-translate-y-1 hover:shadow-amethyst/20' : '',
    className,
  ]}
  style={`border-color: color-mix(in srgb, ${accent} 45%, transparent);`}
>
  <div class="flex items-center justify-between text-[0.65rem] uppercase tracking-widest text-mist">
    <span style={`color: ${accent};`}>{corner}</span>
    <span>{arcana.kind === 'major' ? 'Major' : arcana.suit}</span>
  </div>

  <div class="mt-2 flex aspect-square items-center justify-center rounded-lg bg-void/50">
    <img
      src={card.sprite}
      alt={card.name}
      loading="lazy"
      class="h-full w-full object-contain drop-shadow-[0_0_12px_rgba(124,92,255,0.25)] transition group-hover:scale-105"
    />
  </div>

  <div class="mt-3 text-center">
    <p class="font-display text-sm capitalize text-moonlight">{card.name}</p>
    <p class="mt-0.5 text-xs" style={`color: ${accent};`}>{arcana.name}</p>
  </div>

  <span
    class="pointer-events-none absolute inset-x-0 bottom-0 h-1"
    style={`background: linear-gradient(90deg, transparent, ${accent}, transparent);`}
  ></span>
</Tag>
