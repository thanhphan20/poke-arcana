---
const MONTHS = [
  'January', 'February', 'March', 'April', 'May', 'June',
  'July', 'August', 'September', 'October', 'November', 'December',
] as const;

const CURRENT_YEAR = new Date().getFullYear();
const EARLIEST_YEAR = 1925;
const YEARS = Array.from({ length: CURRENT_YEAR - EARLIEST_YEAR + 1 }, (_, i) => CURRENT_YEAR - i);

const HOURS = Array.from({ length: 24 }, (_, i) => i);
const MINUTES = Array.from({ length: 60 }, (_, i) => i);
---

<div class="birth-form" data-birth-form>
  <p class="birth-form__kicker">Find Your Signs</p>
  <form data-birth-form-el>
    <div class="birth-form__row">
      <div class="birth-form__select-wrap">
        <select class="birth-form__select" data-birth-month aria-label="Birth month" required>
          <option value="" disabled selected>Month</option>
          {MONTHS.map((m, i) => <option value={i + 1}>{m}</option>)}
        </select>
      </div>
      <div class="birth-form__select-wrap">
        <select class="birth-form__select birth-form__select--day" data-birth-day aria-label="Birth day" required>
          <option value="" disabled selected>Day</option>
          {Array.from({ length: 31 }, (_, i) => <option value={i + 1}>{i + 1}</option>)}
        </select>
      </div>
      <div class="birth-form__select-wrap">
        <select class="birth-form__select birth-form__select--year" data-birth-year aria-label="Birth year" required>
          <option value="" disabled selected>Year</option>
          {YEARS.map((y) => <option value={y}>{y}</option>)}
        </select>
      </div>
    </div>

    <div class="birth-form__row birth-form__row--secondary">
      <div class="birth-form__select-wrap">
        <select class="birth-form__select birth-form__select--time" data-birth-hour aria-label="Birth hour (optional, for rising sign)">
          <option value="" selected>Hour</option>
          {HOURS.map((h) => <option value={h}>{String(h).padStart(2, '0')}</option>)}
        </select>
      </div>
      <div class="birth-form__select-wrap">
        <select class="birth-form__select birth-form__select--time" data-birth-minute aria-label="Birth minute (optional, for rising sign)">
          <option value="" selected>Min</option>
          {MINUTES.map((m) => <option value={m}>{String(m).padStart(2, '0')}</option>)}
        </select>
      </div>
      <div class="birth-form__city-wrap">
        <input
          type="text"
          class="birth-form__city-input"
          data-birth-city
          placeholder="Birth city (optional, for rising sign)"
          autocomplete="off"
          aria-label="Birth city"
        />
        <ul class="birth-form__city-results" data-birth-city-results hidden></ul>
      </div>
    </div>

    <button type="submit" class="birth-form__submit">Locate My Signs</button>
  </form>

  <div class="birth-form__result" data-birth-result hidden aria-live="polite">
    <div class="birth-form__reading" data-birth-reading></div>

    <div class="birth-form__synthesis-row" data-synthesis-row>
      <p class="birth-form__synthesis-cue">✧ See how it all fits together ✧</p>
      <button type="button" class="birth-form__synthesis-btn" data-synthesis-btn>Weave My Chart Together</button>
      <p class="birth-form__synthesis-error" data-synthesis-error hidden></p>
    </div>
    <div class="birth-form__synthesis" data-synthesis-panel hidden aria-live="polite">
      <p class="birth-form__synthesis-label">✦ Your Chart, Woven Together ✦</p>
      <p class="birth-form__synthesis-text" data-synthesis-text></p>
      <p class="birth-form__synthesis-attribution" data-synthesis-attribution></p>
    </div>

    <button type="button" class="birth-form__clear" data-birth-clear>✕ Forget my birth details</button>
  </div>
</div>

<script>
  import { signForDate, cardInfoForSign } from '../../lib/arcana/zodiac';
  import { moonSignForDate } from '../../lib/arcana/moon';
  import { risingSignForBirth } from '../../lib/arcana/ascendant';
  import { planetSignForDate, type PlanetKey } from '../../lib/arcana/planets';
  import { searchCities, type CityResult } from '../../lib/arcana/geocoding';
  import { getBirthDetails, saveBirthDetails, clearBirthDetails, type BirthCity } from '../../lib/birth';
  import type { NatalPromptPoint } from '../../lib/ai/natal/prompt';

  // Days-in-month, ignoring leap years (day-of-month only matters here for
  // narrowing the <select>, not for real calendar validity).
  const DAYS_IN_MONTH = [31, 29, 31, 30, 31, 30, 31, 31, 30, 31, 30, 31];

  const root = document.querySelector<HTMLElement>('[data-birth-form]');
  if (root) {
    const form = root.querySelector<HTMLFormElement>('[data-birth-form-el]')!;
    const monthSelect = root.querySelector<HTMLSelectElement>('[data-birth-month]')!;
    const daySelect = root.querySelector<HTMLSelectElement>('[data-birth-day]')!;
    const yearSelect = root.querySelector<HTMLSelectElement>('[data-birth-year]')!;
    const hourSelect = root.querySelector<HTMLSelectElement>('[data-birth-hour]')!;
    const minuteSelect = root.querySelector<HTMLSelectElement>('[data-birth-minute]')!;
    const cityInput = root.querySelector<HTMLInputElement>('[data-birth-city]')!;
    const cityResultsEl = root.querySelector<HTMLElement>('[data-birth-city-results]')!;
    const result = root.querySelector<HTMLElement>('[data-birth-result]')!;
    const readingEl = root.querySelector<HTMLElement>('[data-birth-reading]')!;
    const clearBtn = root.querySelector<HTMLButtonElement>('[data-birth-clear]')!;
    const synthesisRow = root.querySelector<HTMLElement>('[data-synthesis-row]')!;
    const synthesisBtn = root.querySelector<HTMLButtonElement>('[data-synthesis-btn]')!;
    const synthesisError = root.querySelector<HTMLElement>('[data-synthesis-error]')!;
    const synthesisPanel = root.querySelector<HTMLElement>('[data-synthesis-panel]')!;
    const synthesisText = root.querySelector<HTMLElement>('[data-synthesis-text]')!;
    const synthesisAttribution = root.querySelector<HTMLElement>('[data-synthesis-attribution]')!;

    let selectedCity: BirthCity | null = null;
    let cityQueryTimer: ReturnType<typeof setTimeout> | undefined;
    let cityAbort: AbortController | null = null;
    let currentPoints: NatalPromptPoint[] = [];

    function locate(sunSign: string | null, moonSign: string | null, risingSign: string | null) {
      window.dispatchEvent(new CustomEvent('star-map:locate', { detail: { sunSign, moonSign, risingSign } }));
    }

    interface Point { icon: string; name: string; hint: string; sign: string }

    // Colorful inline SVGs (not keyboard glyphs) — colors match the star
    // map's gold/silver/peach ring colors for the same three points.
    const SUN_ICON =
      '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">' +
      '<circle cx="12" cy="12" r="5" fill="#f3dfa2"/>' +
      '<g stroke="#cba85a" stroke-width="2" stroke-linecap="round">' +
      '<line x1="12" y1="1" x2="12" y2="4"/><line x1="12" y1="20" x2="12" y2="23"/>' +
      '<line x1="1" y1="12" x2="4" y2="12"/><line x1="20" y1="12" x2="23" y2="12"/>' +
      '<line x1="4.2" y1="4.2" x2="6.3" y2="6.3"/><line x1="17.7" y1="17.7" x2="19.8" y2="19.8"/>' +
      '<line x1="4.2" y1="19.8" x2="6.3" y2="17.7"/><line x1="17.7" y1="6.3" x2="19.8" y2="4.2"/>' +
      '</g></svg>';

    const MOON_ICON =
      '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">' +
      '<path d="M20 14.5A9 9 0 1 1 9.5 4a7 7 0 0 0 10.5 10.5Z" fill="#dbe4ff" stroke="#a7b8f5" stroke-width="1"/>' +
      '</svg>';

    const RISING_ICON =
      '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">' +
      '<path d="M4 18h16" stroke="#e8915a" stroke-width="2" stroke-linecap="round"/>' +
      '<path d="M6 18a6 6 0 0 1 12 0" fill="#ffd9b8" stroke="#e8915a" stroke-width="1.5"/>' +
      '<path d="M12 3v7m0 0-3-3m3 3 3-3" stroke="#e8915a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>' +
      '</svg>';

    // Simplified vector icons for the 8 classical/modern planets — colorful
    // and thematic rather than pixel-exact astrological glyphs.
    const MERCURY_ICON =
      '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">' +
      '<path d="M8 6a4 4 0 0 1 8 0" stroke="#8291a3" stroke-width="1.5"/>' +
      '<circle cx="12" cy="10" r="4" fill="#cfd8e3" stroke="#8291a3" stroke-width="1.5"/>' +
      '<line x1="12" y1="14" x2="12" y2="20" stroke="#8291a3" stroke-width="1.5"/>' +
      '<line x1="9" y1="17" x2="15" y2="17" stroke="#8291a3" stroke-width="1.5"/></svg>';

    const VENUS_ICON =
      '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">' +
      '<circle cx="12" cy="9" r="5" fill="#ffcfe0" stroke="#d97ea9" stroke-width="1.5"/>' +
      '<line x1="12" y1="14" x2="12" y2="21" stroke="#d97ea9" stroke-width="1.5"/>' +
      '<line x1="8" y1="18" x2="16" y2="18" stroke="#d97ea9" stroke-width="1.5"/></svg>';

    const MARS_ICON =
      '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">' +
      '<circle cx="10" cy="14" r="5" fill="#ff9a86" stroke="#c8402b" stroke-width="1.5"/>' +
      '<line x1="13" y1="11" x2="19" y2="5" stroke="#c8402b" stroke-width="1.5"/>' +
      '<path d="M14 5h5v5" stroke="#c8402b" stroke-width="1.5" fill="none"/></svg>';

    const JUPITER_ICON =
      '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">' +
      '<path d="M6 6c3 0 5 1.5 5 4s-2 3-4 3h9" stroke="#a98ce8" stroke-width="2" stroke-linecap="round" fill="none"/>' +
      '<line x1="16" y1="4" x2="16" y2="19" stroke="#a98ce8" stroke-width="2" stroke-linecap="round"/></svg>';

    const SATURN_ICON =
      '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">' +
      '<line x1="9" y1="4" x2="9" y2="18" stroke="#c9a86a" stroke-width="2" stroke-linecap="round"/>' +
      '<line x1="6" y1="8" x2="13" y2="8" stroke="#c9a86a" stroke-width="2" stroke-linecap="round"/>' +
      '<path d="M9 15c0 3 5 3 5-0.5s-3-3-4-1.5" stroke="#c9a86a" stroke-width="2" stroke-linecap="round" fill="none"/></svg>';

    const URANUS_ICON =
      '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">' +
      '<circle cx="12" cy="17" r="2.6" fill="#9fe9e6" stroke="#3fb8b4" stroke-width="1.3"/>' +
      '<line x1="12" y1="14.5" x2="12" y2="6" stroke="#3fb8b4" stroke-width="1.5"/>' +
      '<line x1="6.5" y1="9" x2="17.5" y2="9" stroke="#3fb8b4" stroke-width="1.5"/>' +
      '<line x1="6.5" y1="5" x2="6.5" y2="12" stroke="#3fb8b4" stroke-width="1.5"/>' +
      '<line x1="17.5" y1="5" x2="17.5" y2="12" stroke="#3fb8b4" stroke-width="1.5"/></svg>';

    const NEPTUNE_ICON =
      '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">' +
      '<line x1="12" y1="5" x2="12" y2="20" stroke="#6f8fe8" stroke-width="2" stroke-linecap="round"/>' +
      '<path d="M7 6c0 4.5 3 6.5 5 6.5s5-2 5-6.5" stroke="#6f8fe8" stroke-width="2" stroke-linecap="round" fill="none"/>' +
      '<line x1="8.5" y1="17" x2="15.5" y2="17" stroke="#6f8fe8" stroke-width="2" stroke-linecap="round"/></svg>';

    const PLUTO_ICON =
      '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">' +
      '<circle cx="12" cy="7" r="3" fill="#d3a3e8" stroke="#8a4bab" stroke-width="1.3"/>' +
      '<path d="M8 12a4 4 0 0 0 8 0" stroke="#8a4bab" stroke-width="1.5" fill="none"/>' +
      '<line x1="12" y1="12" x2="12" y2="20" stroke="#8a4bab" stroke-width="1.5"/>' +
      '<line x1="9" y1="17" x2="15" y2="17" stroke="#8a4bab" stroke-width="1.5"/></svg>';

    const POINT_INFO: Record<'sun' | 'moon' | 'rising', { icon: string; name: string; hint: string }> = {
      sun: { icon: SUN_ICON, name: 'Sun', hint: 'who you are at your core' },
      moon: { icon: MOON_ICON, name: 'Moon', hint: 'your inner emotional world' },
      rising: { icon: RISING_ICON, name: 'Rising', hint: 'the first impression you give' },
    };

    const PLANET_POINT_INFO: Record<PlanetKey, { icon: string; name: string; hint: string }> = {
      mercury: { icon: MERCURY_ICON, name: 'Mercury', hint: 'how you think and communicate' },
      venus: { icon: VENUS_ICON, name: 'Venus', hint: 'what you love and value' },
      mars: { icon: MARS_ICON, name: 'Mars', hint: 'how you act and go after what you want' },
      jupiter: { icon: JUPITER_ICON, name: 'Jupiter', hint: 'where you grow and find luck' },
      saturn: { icon: SATURN_ICON, name: 'Saturn', hint: 'your discipline and hard-won lessons' },
      uranus: { icon: URANUS_ICON, name: 'Uranus', hint: 'where you break the mold' },
      neptune: { icon: NEPTUNE_ICON, name: 'Neptune', hint: 'your dreams and intuition' },
      pluto: { icon: PLUTO_ICON, name: 'Pluto', hint: 'where you transform and grow powerful' },
    };
    const PLANET_ORDER: PlanetKey[] = ['mercury', 'venus', 'mars', 'jupiter', 'saturn', 'uranus', 'neptune', 'pluto'];

    // Groups points that land on the same sign into one card (preserving
    // input order) instead of repeating an identical card line per point.
    function groupBySign(points: Point[]): Point[][] {
      const order: string[] = [];
      const groups = new Map<string, Point[]>();
      for (const p of points) {
        if (!groups.has(p.sign)) {
          groups.set(p.sign, []);
          order.push(p.sign);
        }
        groups.get(p.sign)!.push(p);
      }
      return order.map((sign) => groups.get(sign)!);
    }

    function buildReadingCard(group: Point[], size: 'big' | 'compact'): HTMLElement {
      const sign = group[0].sign;
      const info = cardInfoForSign(sign);

      const card = document.createElement('div');
      card.className = `birth-form__card birth-form__card--${size}`;

      const badge = document.createElement('span');
      badge.className = 'birth-form__card-badge';
      badge.innerHTML = group.map((p) => p.icon).join('');

      const body = document.createElement('div');
      body.className = 'birth-form__card-body';

      const head = document.createElement('p');
      head.className = 'birth-form__card-head';

      const nameEl = document.createElement('span');
      nameEl.className = 'birth-form__card-point';
      nameEl.textContent = group.map((p) => p.name).join(' & ');

      const hintEl = document.createElement('span');
      hintEl.className = 'birth-form__card-hint';
      hintEl.textContent = group[0].hint;

      // A real text-node separator (not just a CSS gap) so copy/pasted text
      // doesn't jam "Sun & Venuswho you are..." together.
      head.append(nameEl, document.createTextNode(' — '), hintEl);

      const cardLine = document.createElement('p');
      cardLine.className = 'birth-form__card-sign';
      cardLine.textContent = `${sign} → ${info.cardName} (${info.pokemonName})`;

      const meaning = document.createElement('p');
      meaning.className = 'birth-form__card-meaning';
      meaning.textContent = info.uprightMeaning;

      body.append(head, cardLine, meaning);
      card.append(badge, body);
      return card;
    }

    function buildSection(title: string, groups: Point[][], size: 'big' | 'compact'): HTMLElement {
      const section = document.createElement('section');
      section.className = 'birth-form__section';

      const heading = document.createElement('h3');
      heading.className = 'birth-form__section-title';
      heading.textContent = title;

      const grid = document.createElement('div');
      grid.className = `birth-form__grid birth-form__grid--${size}`;
      for (const group of groups) grid.appendChild(buildReadingCard(group, size));

      section.append(heading, grid);
      return section;
    }

    function showResult(
      sunSign: string, moonSign: string, risingSign: string | null,
      planetSigns: Record<PlanetKey, string>,
    ) {
      readingEl.replaceChildren();

      const bigThreePoints: Point[] = [
        { ...POINT_INFO.sun, sign: sunSign },
        { ...POINT_INFO.moon, sign: moonSign },
      ];
      if (risingSign) bigThreePoints.push({ ...POINT_INFO.rising, sign: risingSign });

      const planetPoints: Point[] = PLANET_ORDER.map((key) => ({ ...PLANET_POINT_INFO[key], sign: planetSigns[key] }));

      readingEl.appendChild(buildSection('The Big Three', groupBySign(bigThreePoints), 'big'));
      readingEl.appendChild(buildSection('Your Planets', groupBySign(planetPoints), 'compact'));

      currentPoints = [...bigThreePoints, ...planetPoints].map((p) => {
        const info = cardInfoForSign(p.sign);
        return {
          label: p.name, sign: p.sign, cardName: info.cardName,
          keywords: info.keywords, uprightMeaning: info.uprightMeaning, pokemonName: info.pokemonName,
        };
      });
      resetSynthesis();
      result.hidden = false;
    }

    function resetSynthesis() {
      synthesisPanel.hidden = true;
      synthesisText.textContent = '';
      synthesisAttribution.textContent = '';
      synthesisError.hidden = true;
      synthesisRow.hidden = false;
      synthesisBtn.disabled = false;
      synthesisBtn.textContent = 'Weave My Chart Together';
    }

    async function requestSynthesis() {
      if (currentPoints.length < 2) return;
      synthesisBtn.disabled = true;
      synthesisBtn.textContent = 'The stars are aligning…';
      synthesisError.hidden = true;

      try {
        const res = await fetch('/api/natal-reading', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ points: currentPoints }),
        });
        if (!res.ok) throw new Error('request failed');

        const data = (await res.json()) as { provider: string; synthesis: string };
        synthesisText.textContent = data.synthesis;
        synthesisAttribution.textContent = `✦ read by ${data.provider} ✦`;
        synthesisPanel.hidden = false;
        synthesisRow.hidden = true;
      } catch {
        synthesisBtn.disabled = false;
        synthesisBtn.textContent = 'Weave My Chart Together';
        synthesisError.textContent = 'The stars are quiet — try again in a moment.';
        synthesisError.hidden = false;
      }
    }

    synthesisBtn.addEventListener('click', () => { void requestSynthesis(); });

    // Hide day options past the selected month's length, clamping the
    // current selection down if needed (e.g. switching from Jan 31 to Feb).
    function syncDayOptions() {
      const max = DAYS_IN_MONTH[Number(monthSelect.value) - 1] ?? 31;
      let clampedSelection = false;
      for (const opt of Array.from(daySelect.options)) {
        if (!opt.value) continue;
        const hide = Number(opt.value) > max;
        opt.hidden = hide;
        opt.disabled = hide;
        if (hide && opt.selected) clampedSelection = true;
      }
      if (clampedSelection) daySelect.value = '';
    }

    monthSelect.addEventListener('change', syncDayOptions);

    // ─── City autocomplete ────────────────────────────────────────────────

    function hideCityResults() {
      cityResultsEl.hidden = true;
      cityResultsEl.replaceChildren();
    }

    function renderCityResults(cities: CityResult[]) {
      cityResultsEl.replaceChildren();
      if (cities.length === 0) {
        hideCityResults();
        return;
      }
      for (const city of cities) {
        const li = document.createElement('li');
        li.className = 'birth-form__city-option';
        li.textContent = city.label;
        li.addEventListener('click', () => {
          selectedCity = { label: city.label, lat: city.lat, lng: city.lng, tz: city.tz };
          cityInput.value = city.label;
          hideCityResults();
        });
        cityResultsEl.appendChild(li);
      }
      cityResultsEl.hidden = false;
    }

    cityInput.addEventListener('input', () => {
      selectedCity = null; // must re-pick a suggestion — avoids submitting an unresolved city
      clearTimeout(cityQueryTimer);
      cityAbort?.abort();

      const query = cityInput.value;
      if (query.trim().length < 2) {
        hideCityResults();
        return;
      }
      cityQueryTimer = setTimeout(async () => {
        cityAbort = new AbortController();
        const cities = await searchCities(query, cityAbort.signal);
        renderCityResults(cities);
      }, 300);
    });

    document.addEventListener('click', (e) => {
      if (!root.contains(e.target as Node)) return;
      if (!cityInput.contains(e.target as Node) && !cityResultsEl.contains(e.target as Node)) {
        hideCityResults();
      }
    });

    // ─── Compute + persist ──────────────────────────────────────────────────

    function computeSigns(
      year: number, month: number, day: number,
      hour: number | null, minute: number | null, city: BirthCity | null,
    ) {
      const sunSign = signForDate(month, day);
      const moonSign = moonSignForDate(year, month, day);
      const risingSign =
        hour !== null && minute !== null && city
          ? risingSignForBirth(year, month, day, hour, minute, city)
          : null;
      const planetSigns = Object.fromEntries(
        PLANET_ORDER.map((key) => [key, planetSignForDate(key, year, month, day)]),
      ) as Record<PlanetKey, string>;
      return { sunSign, moonSign, risingSign, planetSigns };
    }

    // Restore birth details saved on a previous visit, and re-locate its
    // signs once the star-map custom element has finished connecting.
    const saved = getBirthDetails();
    if (saved) {
      const [year, month, day] = saved.date.split('-').map(Number);
      monthSelect.value = String(month);
      syncDayOptions();
      daySelect.value = String(day);
      yearSelect.value = String(year);
      if (saved.hour !== undefined) hourSelect.value = String(saved.hour);
      if (saved.minute !== undefined) minuteSelect.value = String(saved.minute);
      if (saved.city) {
        selectedCity = saved.city;
        cityInput.value = saved.city.label;
      }

      const { sunSign, moonSign, risingSign, planetSigns } = computeSigns(
        year, month, day,
        saved.hour ?? null, saved.minute ?? null, saved.city,
      );
      showResult(sunSign, moonSign, risingSign, planetSigns);
      customElements.whenDefined('star-map').then(() => locate(sunSign, moonSign, risingSign));
    }

    form.addEventListener('submit', (e) => {
      e.preventDefault();
      if (!monthSelect.value || !daySelect.value || !yearSelect.value) return;

      const month = Number(monthSelect.value);
      const day = Number(daySelect.value);
      const year = Number(yearSelect.value);
      const hour = hourSelect.value ? Number(hourSelect.value) : null;
      const minute = minuteSelect.value ? Number(minuteSelect.value) : null;

      const { sunSign, moonSign, risingSign, planetSigns } = computeSigns(year, month, day, hour, minute, selectedCity);

      saveBirthDetails({
        date: `${year}-${String(month).padStart(2, '0')}-${String(day).padStart(2, '0')}`,
        hour: hour ?? 0,
        minute: minute ?? 0,
        city: selectedCity,
      });
      showResult(sunSign, moonSign, risingSign, planetSigns);
      locate(sunSign, moonSign, risingSign);
    });

    clearBtn.addEventListener('click', () => {
      clearBirthDetails();
      monthSelect.value = '';
      daySelect.value = '';
      yearSelect.value = '';
      hourSelect.value = '';
      minuteSelect.value = '';
      cityInput.value = '';
      selectedCity = null;
      syncDayOptions();
      hideCityResults();
      result.hidden = true;
      currentPoints = [];
      locate(null, null, null);
    });
  }
</script>

