---
import type { CollectionEntry } from 'astro:content';
import TarotCard from './TarotCard.astro';
import { SUIT_META } from '../lib/arcana/meanings';

interface Props {
  cards: CollectionEntry<'pokemonCards'>[];
}

const { cards } = Astro.props;

const ALL_MAJOR_ACCENT = '#cba85a';

const filters = [
  { key: 'all', label: 'All', accent: ALL_MAJOR_ACCENT },
  { key: 'major', label: 'Major', accent: ALL_MAJOR_ACCENT },
  { key: 'cups', label: 'Cups', accent: SUIT_META.cups.color },
  { key: 'wands', label: 'Wands', accent: SUIT_META.wands.color },
  { key: 'swords', label: 'Swords', accent: SUIT_META.swords.color },
  { key: 'pentacles', label: 'Pentacles', accent: SUIT_META.pentacles.color },
] as const;

const sorted = cards.slice().sort((a, b) => a.data.id - b.data.id);
---

<div class="deck">
  <div
    class="deck-filters"
    style="display:flex; flex-wrap:wrap; justify-content:center; gap:9px; margin:34px 0 40px;"
    role="group"
    aria-label="Filter cards"
  >
    {
      filters.map((f) => (
        <button
          type="button"
          class="deck-pill"
          data-filter={f.key}
          data-accent={f.accent}
          aria-pressed={f.key === 'all' ? 'true' : 'false'}
          style={`padding:8px 18px; border-radius:999px; cursor:pointer; font-family:'Cinzel',serif; font-size:12px; letter-spacing:.12em; text-transform:uppercase; transition:all .3s; color:${
            f.key === 'all' ? '#0b0714' : '#c8bfe0'
          }; background:${f.key === 'all' ? f.accent : 'transparent'}; border:1px solid ${
            f.key === 'all' ? f.accent : 'rgba(167,139,250,.35)'
          };`}
        >
          {f.label}
        </button>
      ))
    }
  </div>

  <div style="display:grid; grid-template-columns:repeat(auto-fill,minmax(150px,1fr)); gap:22px;">
    {
      sorted.map((entry) => (
        <div class="deck-item" data-kind={entry.data.arcana.kind} data-suit={entry.data.arcana.suit ?? ''}>
          <TarotCard card={entry.data} href={'/deck/' + entry.data.slug} />
        </div>
      ))
    }
  </div>
</div>

<style>
  .deck-item.hidden {
    display: none;
  }
</style>

<script>
  const root = document.querySelector<HTMLElement>('.deck') ?? document.body;
  const pills = Array.from(root.querySelectorAll<HTMLButtonElement>('.deck-pill'));
  const items = Array.from(root.querySelectorAll<HTMLElement>('.deck-item'));

  function apply(filter: string) {
    for (const item of items) {
      const kind = item.dataset.kind;
      const suit = item.dataset.suit;
      let visible = true;
      if (filter === 'major') visible = kind === 'major';
      else if (filter !== 'all') visible = kind === 'minor' && suit === filter;
      item.classList.toggle('hidden', !visible);
    }

    for (const pill of pills) {
      const active = pill.dataset.filter === filter;
      const accent = pill.dataset.accent ?? '#cba85a';
      pill.setAttribute('aria-pressed', active ? 'true' : 'false');
      pill.style.color = active ? '#0b0714' : '#c8bfe0';
      pill.style.background = active ? accent : 'transparent';
      pill.style.border = active ? `1px solid ${accent}` : '1px solid rgba(167,139,250,.35)';
    }
  }

  for (const pill of pills) {
    pill.addEventListener('click', () => apply(pill.dataset.filter ?? 'all'));
  }
</script>
