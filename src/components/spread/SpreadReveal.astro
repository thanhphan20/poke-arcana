---
import type { CollectionEntry } from "astro:content";
import { MAJOR_ARCANA_METADATA, MINOR_ARCANA_METADATA } from "../../lib/arcana/tarot-metadata";

interface Props {
    cards: CollectionEntry<"tarotCards">[];
}

const { cards } = Astro.props;

const RANK_NAMES = ['Ace','Two','Three','Four','Five','Six','Seven','Eight','Nine','Ten','Page','Knight','Queen','King'] as const;

const payload = cards.map((c) => {
    const arc = c.data.arcana;
    const meta =
        arc.kind === 'major'
            ? (MAJOR_ARCANA_METADATA[arc.name] ?? null)
            : (MINOR_ARCANA_METADATA[arc.suit ?? 'cups']?.[RANK_NAMES[arc.rankIndex ?? 0]] ?? null);

    return {
        slug: c.data.slug,
        arcana: {
            kind: arc.kind,
            name: arc.name,
            suit: arc.suit,
            majorNumber: arc.majorNumber,
            metadata: meta
                ? {
                    keywords: meta.keywords,
                    uprightMeaning: meta.uprightMeaning,
                    description: meta.description,
                  }
                : null,
        },
        members: c.data.members.map((m) => ({
            id: m.id,
            name: m.name,
            slug: m.slug,
            flavorText: m.flavorText,
        })),
    };
});
---

<spread-reveal data-default-spread="3">
    <script type="application/json" set:html={JSON.stringify(payload)} is:inline />

    <p data-instruction class="spread-instruction">
        Draw three cards from the deck below.
    </p>
    <p data-counter class="spread-counter">Drawn 0 / 3</p>

    <div data-slots class="spread-slots"></div>

    <div data-reading-panel class="reading-panel" hidden></div>

    <div data-fortune-row class="fortune-row" hidden>
        <button type="button" data-read-fortune class="fortune-btn"
            >Read My Fortune</button
        >
        <p data-fortune-error class="fortune-error" hidden></p>
    </div>

    <div data-ai-reading class="ai-reading-panel" hidden></div>

    <div data-reset-row class="spread-reset" hidden>
        <button type="button" data-reset class="spread-reset-btn"
            >Shuffle · New Reading</button
        >
    </div>

    <p data-fan-hint class="spread-fan-hint">Hover to lift · click to draw</p>
    <div data-fan class="spread-fan"></div>
</spread-reveal>

<style>
    .spread-instruction {
        margin: 24px 0 2px;
        font-family: "EB Garamond", serif;
        font-style: italic;
        font-size: 18px;
        color: #c8bfe0;
    }
    .spread-counter {
        margin: 0;
        font-family: "Cinzel", serif;
        font-size: 12px;
        letter-spacing: 0.22em;
        text-transform: uppercase;
        color: #cba85a;
    }
    .spread-slots {
        display: flex;
        flex-wrap: wrap;
        align-items: flex-start;
        justify-content: center;
        gap: 24px;
        margin-top: 30px;
        perspective: 1400px;
        min-height: 180px;
    }
    .fortune-row {
        margin-top: 36px;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 12px;
    }
    .fortune-btn {
        padding: 13px 34px;
        border-radius: 999px;
        cursor: pointer;
        font-family: "Cinzel", serif;
        font-size: 12px;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: #0b0714;
        border: none;
        background: linear-gradient(160deg, #e3cf95, #c39a45);
        transition: opacity 0.25s, transform 0.2s;
    }
    .fortune-btn:hover:not(:disabled) {
        transform: translateY(-1px);
    }
    .fortune-btn:focus-visible {
        outline: 2px solid #a78bfa;
        outline-offset: 3px;
    }
    .fortune-btn:disabled {
        cursor: default;
        opacity: 0.6;
    }
    .fortune-error {
        margin: 0;
        font-family: "EB Garamond", serif;
        font-style: italic;
        font-size: 14px;
        color: #c8bfe0;
    }
    /* ── AI reading panel — appended below the template reading, never replaces it ── */
    .ai-reading-panel {
        margin: 40px auto 0;
        max-width: 680px;
        text-align: left;
        animation: rp-rise 0.7s cubic-bezier(0.22, 1, 0.36, 1) both;
    }
    :global(.ai-header) {
        text-align: center;
        margin-bottom: 32px;
        padding: 22px 0 24px;
        border-top: 1px solid rgba(124, 92, 255, 0.25);
        border-bottom: 1px solid rgba(124, 92, 255, 0.2);
    }
    :global(.ai-kicker) {
        font-family: "Cinzel", serif;
        font-size: 11px;
        letter-spacing: 0.32em;
        text-transform: uppercase;
        color: #a78bfa;
        margin: 0 0 10px;
    }
    :global(.ai-subtitle) {
        font-family: "EB Garamond", serif;
        font-style: italic;
        font-size: 15px;
        color: #8f86ac;
        margin: 0;
    }
    :global(.ai-card) {
        margin-bottom: 32px;
        padding-left: 20px;
        border-left: 2px solid rgba(124, 92, 255, 0.4);
    }
    :global(.ai-card__title) {
        font-family: "Cinzel", serif;
        font-size: 12px;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: #a78bfa;
        margin: 0 0 10px;
    }
    :global(.ai-card__text) {
        font-family: "EB Garamond", serif;
        font-size: 17px;
        line-height: 1.7;
        color: #c8bfe0;
        margin: 0;
    }
    :global(.ai-synthesis) {
        margin-top: 36px;
        padding: 24px 28px;
        border-radius: 12px;
        border: 1px solid rgba(124, 92, 255, 0.3);
        background: rgba(124, 92, 255, 0.08);
        text-align: center;
    }
    :global(.ai-synthesis__label) {
        font-family: "Cinzel", serif;
        font-size: 11px;
        letter-spacing: 0.28em;
        text-transform: uppercase;
        color: #a78bfa;
        margin: 0 0 12px;
    }
    :global(.ai-synthesis__text) {
        font-family: "EB Garamond", serif;
        font-style: italic;
        font-size: 16px;
        line-height: 1.7;
        color: #c8bfe0;
        margin: 0;
    }
    :global(.ai-attribution) {
        margin-top: 18px;
        font-family: "Cinzel", serif;
        font-size: 10px;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: #5a5273;
        text-align: center;
    }

    .spread-reset {
        margin-top: 30px;
    }
    .spread-reset-btn {
        padding: 11px 28px;
        border-radius: 999px;
        cursor: pointer;
        font-family: "Cinzel", serif;
        font-size: 12px;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: #e9e4f5;
        border: 1px solid rgba(167, 139, 250, 0.5);
        background: rgba(124, 92, 255, 0.12);
    }
    .spread-fan-hint {
        margin: 40px 0 0;
        font-family: "Cinzel", serif;
        font-size: 11px;
        letter-spacing: 0.28em;
        text-transform: uppercase;
        color: #5a5273;
    }
    .spread-fan {
        position: relative;
        width: 100%;
        height: 360px;
        margin: 0 auto 140px;
    }

    /* ── Per-slot brief arcana hint (phase 1) ── */
    :global(.slot-reading) {
        margin-top: 12px;
        text-align: center;
    }
    :global(.slot-upright) {
        font-family: "EB Garamond", serif;
        font-style: italic;
        font-size: 13px;
        line-height: 1.5;
        color: #a89cc8;
        margin: 0;
    }
    :global(.slot-divider) {
        margin: 10px auto;
        width: 32px;
        height: 1px;
        background: rgba(203, 168, 90, 0.3);
    }
    :global(.slot-flavor-name) {
        font-family: "Cinzel", serif;
        font-size: 10px;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: #7c5cff;
        margin-bottom: 4px;
    }
    :global(.slot-flavor) {
        font-family: "EB Garamond", serif;
        font-style: italic;
        font-size: 13px;
        line-height: 1.5;
        color: #c8bfe0;
        margin: 0;
    }

    /* ── Full reading panel ── */
    .reading-panel {
        margin: 48px auto 0;
        max-width: 680px;
        text-align: left;
        animation: rp-rise 0.7s cubic-bezier(0.22, 1, 0.36, 1) both;
    }
    @keyframes rp-rise {
        from { opacity: 0; transform: translateY(24px); }
        to   { opacity: 1; transform: translateY(0); }
    }
    :global(.rp-header) {
        text-align: center;
        margin-bottom: 36px;
        padding-bottom: 28px;
        border-bottom: 1px solid rgba(203, 168, 90, 0.2);
    }
    :global(.rp-kicker) {
        font-family: "Cinzel", serif;
        font-size: 11px;
        letter-spacing: 0.32em;
        text-transform: uppercase;
        color: #a78bfa;
        margin: 0 0 12px;
    }
    :global(.rp-question) {
        font-family: "Cinzel Decorative", serif;
        font-size: clamp(18px, 2.5vw, 24px);
        font-weight: 700;
        color: #f3dfa2;
        margin: 0 0 14px;
        line-height: 1.3;
    }
    :global(.rp-intro) {
        font-family: "EB Garamond", serif;
        font-style: italic;
        font-size: 16px;
        color: #8f86ac;
        margin: 0;
    }
    :global(.rp-card) {
        margin-bottom: 32px;
        padding-left: 20px;
        border-left: 2px solid rgba(203, 168, 90, 0.35);
    }
    :global(.rp-card__title) {
        font-family: "Cinzel", serif;
        font-size: 12px;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: #cba85a;
        margin: 0 0 10px;
    }
    :global(.rp-card__text) {
        font-family: "EB Garamond", serif;
        font-size: 17px;
        line-height: 1.7;
        color: #c8bfe0;
        margin: 0 0 10px;
    }
    :global(.rp-card__pokemon) {
        font-family: "EB Garamond", serif;
        font-size: 15px;
        line-height: 1.6;
        color: #8f86ac;
        margin: 0;
    }
    :global(.rp-card__pokemon-name) {
        font-family: "Cinzel", serif;
        font-size: 10px;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: #7c5cff;
        margin-right: 6px;
    }
    :global(.rp-synthesis) {
        margin-top: 36px;
        padding: 24px 28px;
        border-radius: 12px;
        border: 1px solid rgba(167, 139, 250, 0.22);
        background: rgba(124, 92, 255, 0.06);
        text-align: center;
    }
    :global(.rp-synthesis__label) {
        font-family: "Cinzel", serif;
        font-size: 11px;
        letter-spacing: 0.28em;
        text-transform: uppercase;
        color: #a78bfa;
        margin: 0 0 12px;
    }
    :global(.rp-synthesis__text) {
        font-family: "EB Garamond", serif;
        font-style: italic;
        font-size: 16px;
        line-height: 1.7;
        color: #c8bfe0;
        margin: 0;
    }
    :global(.rp-ai-note) {
        margin-top: 28px;
        font-family: "Cinzel", serif;
        font-size: 10px;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: #3d3455;
        text-align: center;
    }
</style>

<script src="./spread-reveal.ts"></script>
