---
import type { CollectionEntry } from "astro:content";
import { MAJOR_ARCANA_METADATA, MINOR_ARCANA_METADATA } from "../../lib/arcana/tarot-metadata";
import "../../styles/reading.css";

interface Props {
    cards: CollectionEntry<"tarotCards">[];
}

const { cards } = Astro.props;

const RANK_NAMES = ['Ace','Two','Three','Four','Five','Six','Seven','Eight','Nine','Ten','Page','Knight','Queen','King'] as const;

const payload = cards.map((c) => {
    const arc = c.data.arcana;
    const meta =
        arc.kind === 'major'
            ? (MAJOR_ARCANA_METADATA[arc.name] ?? null)
            : (MINOR_ARCANA_METADATA[arc.suit ?? 'cups']?.[RANK_NAMES[arc.rankIndex ?? 0]] ?? null);

    return {
        slug: c.data.slug,
        arcana: {
            kind: arc.kind,
            name: arc.name,
            suit: arc.suit,
            majorNumber: arc.majorNumber,
            rankIndex: arc.rankIndex,
            metadata: meta
                ? {
                    keywords: meta.keywords,
                    uprightMeaning: meta.uprightMeaning,
                    description: meta.description,
                  }
                : null,
        },
        members: c.data.members.map((m) => ({
            id: m.id,
            name: m.name,
            slug: m.slug,
            flavorText: m.flavorText,
        })),
    };
});
---

<spread-reveal data-default-spread="3">
    <script type="application/json" set:html={JSON.stringify(payload)} is:inline />

    <p data-instruction class="spread-instruction">
        Draw three cards from the deck below.
    </p>
    <p data-counter class="spread-counter">Drawn 0 / 3</p>

    <div data-slots class="spread-slots"></div>

    <div data-reading-panel class="reading-panel" hidden></div>

    <div data-fortune-row class="fortune-row" hidden>
        <p class="fortune-cue">✧ The cards are laid — ready for the oracle to speak? ✧</p>
        <button type="button" data-read-fortune class="fortune-btn"
            >Read My Fortune</button
        >
        <p data-fortune-error class="fortune-error" hidden></p>
    </div>

    <div data-ai-reading class="ai-reading-panel" hidden></div>

    <div data-reset-row class="spread-reset" hidden>
        <button type="button" data-reset class="spread-reset-btn"
            >Shuffle · New Reading</button
        >
    </div>

    <p data-fan-hint class="spread-fan-hint">Hover to lift · click to draw</p>
    <div data-fan class="spread-fan"></div>
</spread-reveal>

<style>
    .spread-instruction {
        margin: 24px 0 2px;
        font-family: "EB Garamond", serif;
        font-style: italic;
        font-size: 18px;
        color: #c8bfe0;
    }
    .spread-counter {
        margin: 0;
        font-family: "Cinzel", serif;
        font-size: 12px;
        letter-spacing: 0.22em;
        text-transform: uppercase;
        color: #cba85a;
    }
    .spread-slots {
        display: flex;
        flex-wrap: wrap;
        align-items: flex-start;
        justify-content: center;
        gap: 24px;
        margin-top: 30px;
        perspective: 1400px;
        min-height: 180px;
    }
    .fortune-row {
        margin-top: 36px;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 12px;
    }
    .fortune-cue {
        margin: 0;
        font-family: "EB Garamond", serif;
        font-style: italic;
        font-size: 15px;
        color: #8f86ac;
        animation: fortune-cue-in 0.8s ease 0.3s both;
    }
    .fortune-btn {
        padding: 13px 34px;
        border-radius: 999px;
        cursor: pointer;
        font-family: "Cinzel", serif;
        font-size: 12px;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: #0b0714;
        border: none;
        background: linear-gradient(160deg, #e3cf95, #c39a45);
        transition: opacity 0.25s, transform 0.2s;
        animation: fortune-glow 2.5s ease-in-out infinite;
    }
    .fortune-btn:hover:not(:disabled) {
        transform: translateY(-1px);
    }
    .fortune-btn:focus-visible {
        outline: 2px solid #a78bfa;
        outline-offset: 3px;
    }
    .fortune-btn:disabled {
        cursor: default;
        opacity: 0.6;
        animation: none;
    }
    @keyframes fortune-glow {
        0%, 100% { box-shadow: 0 0 6px rgba(203, 168, 90, 0.2); }
        50%      { box-shadow: 0 0 22px rgba(203, 168, 90, 0.5); }
    }
    @keyframes fortune-cue-in {
        from { opacity: 0; transform: translateY(6px); }
        to   { opacity: 1; transform: translateY(0); }
    }
    .fortune-error {
        margin: 0;
        font-family: "EB Garamond", serif;
        font-style: italic;
        font-size: 14px;
        color: #c8bfe0;
    }
    .spread-reset {
        margin-top: 30px;
    }
    .spread-reset-btn {
        padding: 11px 28px;
        border-radius: 999px;
        cursor: pointer;
        font-family: "Cinzel", serif;
        font-size: 12px;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: #e9e4f5;
        border: 1px solid rgba(167, 139, 250, 0.5);
        background: rgba(124, 92, 255, 0.12);
    }
    .spread-fan-hint {
        margin: 40px 0 0;
        font-family: "Cinzel", serif;
        font-size: 11px;
        letter-spacing: 0.28em;
        text-transform: uppercase;
        color: #5a5273;
    }
    .spread-fan {
        position: relative;
        width: 100%;
        height: 360px;
        margin: 0 auto 140px;
    }

    /* ── Per-slot brief arcana hint (phase 1) ── */
    :global(.slot-reading) {
        margin-top: 12px;
        text-align: center;
    }
    :global(.slot-upright) {
        font-family: "EB Garamond", serif;
        font-style: italic;
        font-size: 13px;
        line-height: 1.5;
        color: #a89cc8;
        margin: 0;
    }
    :global(.slot-divider) {
        margin: 10px auto;
        width: 32px;
        height: 1px;
        background: rgba(203, 168, 90, 0.3);
    }
    :global(.slot-flavor-name) {
        font-family: "Cinzel", serif;
        font-size: 10px;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: #7c5cff;
        margin-bottom: 4px;
    }
    :global(.slot-flavor) {
        font-family: "EB Garamond", serif;
        font-style: italic;
        font-size: 13px;
        line-height: 1.5;
        color: #c8bfe0;
        margin: 0;
    }

    /* ── Pulsing glow on tappable cards ── */
    :global(.slot-card--pulse) {
        animation: card-tap-pulse 1.4s ease-in-out infinite;
        cursor: pointer;
    }
    @keyframes card-tap-pulse {
        0%, 100% { filter: drop-shadow(0 0 6px rgba(203, 168, 90, 0.25)); }
        50%      { filter: drop-shadow(0 0 24px rgba(203, 168, 90, 0.75)); }
    }

    /* ── "Tap to Reveal" CTA above the drawn-but-hidden card ── */
    :global(.slot-label--tap) {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 4px;
    }
    :global(.slot-label--tap .slot-label-pos) {
        opacity: 0.65;
    }
    :global(.slot-tap-cta) {
        display: inline-block;
        font-family: 'Cinzel', serif;
        font-size: 11px;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: #f3dfa2;
        text-shadow: 0 0 10px rgba(203, 168, 90, 0.6);
        animation: tap-cta-bounce 1.1s ease-in-out infinite;
    }
    @keyframes tap-cta-bounce {
        0%, 100% { transform: translateY(0); opacity: 0.85; }
        50%      { transform: translateY(4px); opacity: 1; }
    }

    @media (prefers-reduced-motion: reduce) {
        :global(.slot-card--pulse) {
            animation: none;
        }
        :global(.slot-card--pulse) {
            filter: drop-shadow(0 0 6px rgba(203, 168, 90, 0.3));
        }
        :global(.slot-tap-cta) {
            animation: none;
        }
        .fortune-btn {
            animation: none;
            box-shadow: 0 0 6px rgba(203, 168, 90, 0.3);
        }
    }

    @media (max-width: 640px) {
        .spread-slots {
            gap: 12px;
            margin-top: 20px;
        }
        .spread-fan-hint {
            margin: 20px 0 0;
        }
        .spread-fan {
            height: 170px;
            margin: 0 auto 32px;
        }
        .fortune-row {
            margin-top: 24px;
        }
        .spread-reset {
            margin-top: 20px;
        }
    }

</style>

<script src="./spread-reveal.ts"></script>
