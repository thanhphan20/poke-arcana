---
// The reverse of a tarot card — a gilt sigil on a deep arcane field.
// Styles live as global classes in global.css so JS-built cards match.
interface Props {
  class?: string;
}
const { class: className = '' } = Astro.props;
---

<div class:list={['card-back', className]}>
  <div class="card-back__field">
    <div class="card-back__ring">
      <span class="card-back__sigil">✦</span>
    </div>
  </div>
</div>
