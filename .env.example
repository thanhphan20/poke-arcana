# Pokedex ID range fetched by scripts/sync-pokedex.ts (inclusive).
# Must cover at least Gen 3 (386) for all 78 tarot cards to receive Pokemon assignments.
DEX_START=1
DEX_END=386

# PokeAPI base URL. Override only if using a mirror/proxy.
POKEAPI_BASE_URL=https://pokeapi.co/api/v2

# Optional: GitHub personal access token (classic, no scopes needed).
# Raises raw.githubusercontent.com rate limit from ~60 to 5 000 req/hour,
# which prevents 429 errors when `bun run sync` downloads Pokemon sprites.
# Create one at https://github.com/settings/tokens
GITHUB_TOKEN=

# Vercel Blob store for uploaded sprites (run `bun run upload-sprites`).
BLOB_STORE_ID=
BLOB_READ_WRITE_TOKEN=

# Public base URL of the Blob store above; read by src/lib/sprites.ts.
PUBLIC_SPRITES_BASE=

# Public base URL of the Vercel Blob store holding Rider-Waite-Smith tarot art
# (run `bun run scripts/upload-tarot-art-to-blob.ts <local-dir>`).
# May point to the same store as PUBLIC_SPRITES_BASE or a separate one.
PUBLIC_TAROT_BASE=

# AI tarot reading provider chain (POST /api/reading), tried in this order:
# Gemini -> Groq -> OpenRouter. All optional — a missing key drops that
# provider from the chain. At least one must be set for AI readings to work;
# with none set, /api/reading returns 503 and the site falls back to the
# template-based reading.

# https://aistudio.google.com/apikey
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash

# https://console.groq.com/keys
GROQ_API_KEY=
# GROQ_MODEL=llama-3.3-70b-versatile

# https://openrouter.ai/keys
OPENROUTER_API_KEY=
# OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
